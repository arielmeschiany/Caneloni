{
  "name": "canaloni",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "web",
    "mobile"
  ],
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "overrides": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "scripts": {
    "web": "npm run dev -w @canaloni/web",
    "mobile": "npm run start -w @canaloni/mobile",
    "shared:build": "npm run build -w @canaloni/shared",
    "install:all": "npm install"
  }
}
